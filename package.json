{
  "name": "taipei-friendly-food-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fetch:data": "tsx scripts/fetchFriendlyFoodData.ts",
    "data:fetch:water-refill": "tsx scripts/fetchWaterRefillStores.ts",
    "data:fetch:food-traceability": "tsx scripts/fetchTaipeiFoodTraceabilityProducts.ts",
    "convert:friendly": "tsx scripts/convertFriendlyStores.ts",
    "convert:restaurants": "tsx scripts/convertRestaurantBusinesses.ts",
    "data:convert:water-refill": "tsx scripts/convertWaterRefillStores.ts",
    "data:convert:food-traceability": "tsx scripts/convertTaipeiFoodTraceabilityProducts.ts",
    "build:summaries": "tsx scripts/buildFriendlyFoodSummaries.ts",
    "data:fetch": "npm run fetch:data && npm run data:fetch:water-refill && npm run data:fetch:food-traceability",
    "convert:data": "npm run convert:friendly && npm run convert:restaurants && npm run data:convert:water-refill && npm run build:summaries && npm run data:convert:food-traceability",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.16"
  }
}
