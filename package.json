{
  "name": "taipei-friendly-food-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fetch:data": "tsx scripts/fetchFriendlyFoodData.ts",
    "convert:friendly": "tsx scripts/convertFriendlyStores.ts",
    "convert:restaurants": "tsx scripts/convertRestaurantBusinesses.ts",
    "build:summaries": "tsx scripts/buildFriendlyFoodSummaries.ts",
    "convert:data": "npm run convert:friendly && npm run convert:restaurants && npm run build:summaries",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.17",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
